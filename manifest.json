{
  "manifest_version": 3,
  "name": "Gemini Clean Local",
  "version": "0.1.0",
  "description": "Local-only Gemini image cleaner with easier one-click download buttons.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": [
        "content/masks.js",
        "content/matcher.js",
        "content/page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": [
        "content/bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
